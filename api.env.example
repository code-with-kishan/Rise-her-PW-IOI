# ========== BACKEND API SERVER SETTINGS ==========
PORT=3000
NODE_ENV=production

# ========== API KEYS ==========
GEMINI_API_KEY=your_gemini_api_key_here

# ========== JWT CONFIGURATION ==========
JWT_SECRET=your_very_secure_jwt_secret_key_minimum_32_characters

# ========== FRONTEND URL (for CORS) ==========
FRONTEND_URL=https://your-vercel-domain.vercel.app
ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app,http://localhost:3000,http://localhost:5173

# ========== DATABASE CONFIGURATION ==========
# Firebase Realtime Database (currently used)
# Firebase configuration will be embedded in the app

# ========== RATE LIMITING ==========
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
